DATABASE_URL=postgresql://user:password@host/database?sslmode=require
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@djambo-app.com
APP_URL=https://djambo-app.com
API_URL=https://api.djambo-app.com
ALLOWED_ORIGINS=https://djambo-app.com,https://www.djambo-app.com
GOOGLE_CLIENT_ID=google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=google-client-secret
VITE_API_BASE_URL=https://api.djambo-app.com
GEMINI_API_KEY=PLACEHOLDER_API_KEY

# Optional: user photo uploads via Cloudflare R2
UPLOAD_STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=djambo-app-uploads
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_PUBLIC_BASE_URL=https://media.djambo-app.com
MAX_UPLOAD_SIZE_MB=10