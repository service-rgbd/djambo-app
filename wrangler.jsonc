{
  "name": "djambo-app",
  "main": "cloudflare/worker.js",
  "compatibility_date": "2026-04-09",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "djambo-app-media"
    }
  ]
}